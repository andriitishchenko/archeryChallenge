# Copy to .env and fill in values

# SECURITY — change this before deploying!
SECRET_KEY=your-very-long-random-secret-key-here

# DATABASE
# SQLite (default, for development):
DATABASE_URL=sqlite:///./arrowmatch.db
# PostgreSQL (for production):
# DATABASE_URL=postgresql://user:password@localhost:5432/arrowmatch

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,https://yourdomain.com

# AUTH RATE LIMITING
AUTH_RATE_LIMIT=5        # max attempts per window
AUTH_RATE_WINDOW=900     # window size in seconds (15 min)

# MATCHMAKING
BOT_WAIT_SECONDS=8       # seconds to wait before spawning a bot
MATCHMAKING_TIMEOUT=30   # total matchmaking timeout in seconds

# TOKEN EXPIRY
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# DEBUG (set false in production — disables /docs and /redoc)
DEBUG=true
